# Supabase public browser config for dashboard auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_placeholder

# Service role used only in server components and route handlers
SUPABASE_SERVICE_ROLE_KEY=sb_secret_placeholder

# Public dashboard URL
NEXT_PUBLIC_APP_URL=http://localhost:3001
